# ─── Riot Games ───────────────────────────────────────────────────────────────
# Personal API key from https://developer.riotgames.com
# Renews every 24h on the dev portal; use a production key for permanent deploys
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── Twitch (optional) ────────────────────────────────────────────────────────
# Default channel shown in the stream embed when no tracked player is live
TWITCH_CHANNEL=your_channel

# App credentials from https://dev.twitch.tv/console/apps
# Required for LIVE badges and profile picture fetching
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ─── Data paths (production / Docker) ─────────────────────────────────────────
# Override these to point to a persistent volume in production.
# Defaults to the project root in development.
# DB_PATH=/data/matches.db
# LP_FILE=/data/lp_history.json
